# ============================================
# Глобальные настройки
# ============================================
EASYOCR_DEVICE=cpu
DEVICE=cuda
REPORT_DIR=report

# ============================================
# Пути к кэшу Hugging Face
# ============================================
HF_HOME=./hf_cache
HF_HUB_CACHE=./hf_cache

# ============================================
# Датасет FUNSD
# ============================================
# DATASET_TRAIN_DIR=FUNSD/training_data
# DATASET_TEST_DIR=FUNSD/testing_data
# DATASET_IMG_DIR=FUNSD/testing_data/images
# DATASET_JSON_DIR=FUNSD/testing_data/annotations

FUNSD_SPLIT_ROOT="./FUNSD_SPLIT"
FUNSD_TRAIN_IMG="./FUNSD_SPLIT/train/images"
FUNSD_TRAIN_JSN="./FUNSD_SPLIT/train/annotations"
FUNSD_VAL_IMG="./FUNSD_SPLIT/val/images"
FUNSD_VAL_JSN="./FUNSD_SPLIT/val/annotations"
FUNSD_TEST_IMG="./FUNSD_SPLIT/test/images"
FUNSD_TEST_JSN="./FUNSD_SPLIT/test/annotations"

# ============================================
# Random Forest (Classic Baseline)
# ============================================
MODEL_PATH_RANDOM_FOREST=models/random_forest/saved_random_forest.joblib
RANDOM_FOREST_MODEL_PATH=models/random_forest/saved_rf_baseline.pkl
RF_N_ESTIMATORS=150
RF_MAX_DEPTH=12

# ============================================
# BERT (Pure NLP)
# ============================================
MODEL_PATH_BERT=models/bert/saved_bert_model
BERT_RESULTS_DIR=models/bert/bert_results
BERT_EPOCHS=5
BERT_BATCH_SIZE=4
BERT_LR=5e-5
BERT_MAX_LENGTH=512

# ============================================
# YOLOv8 (Detection)
# ============================================
YOLO_MODEL_PATH=models/yolo/best.pt
YOLO_PRETRAINED_CACHE=./models/yolo_cache/yolov8n.pt
YOLO_RESULTS_DIR=./models/yolo_runs
YOLO_EPOCHS=15
YOLO_BATCH_SIZE=16
YOLO_IMG_SIZE=640

# ============================================
# LayoutLMv3 (Multimodal)
# ============================================
MODEL_PATH_LAYOUTLMV3=models/layoutlmv3/saved_layoutlmv3_model
LAYOUTLMV3_RESULTS_DIR=models/layoutlmv3/layoutlmv3_results
LAYOUTLM_EPOCHS=5
LAYOUTLM_BATCH_SIZE=2
LAYOUTLM_LR=3e-5
LAYOUTLM_MAX_LENGTH=512

# ============================================
# Qwen2.5-VL ( multimodal )
# ============================================
#QWEN_MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
#QWEN_CONFUSION_MATRIX_OUTPUT=qwen_cascade_confusion_matrix.png

# ============================================
# LiLT (XLM-RoBERTa)
# ============================================
MODEL_PATH_LILT=models/lilt/
LILT_EPOCHS=5
LILT_BATCH_SIZE=2
LILT_LR=4e-5
LILT_MAX_LENGTH=512